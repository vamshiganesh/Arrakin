# Application
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=15s

# Data stores
DATABASE_URL=postgres://arrakin:arrakin@localhost:5432/arrakin?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Settlement engine (used in later phases)
SCHEDULER_INTERVAL=30s
WORKER_COUNT=4
JOB_LEASE_TIMEOUT=5m
MAX_RETRIES=5

# Business defaults (used in later phases)
PLATFORM_FEE_BPS=100
WITHHOLDING_TAX_BPS=1500

# Admin API authentication (optional in development)
API_KEY=dev-local-api-key
